---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<main class="hero">
			<img
				src="/prota-logo.png"
				alt="prota.digital"
				class="logo"
				width="600"
				height="400"
			/>
			<h1>A safe digital childhood.</h1>
			<p class="status">Coming soon.</p>
			<p class="mission">
				Building a digital environment where children can
				learn, play, and communicate safely.
			</p>
		</main>
		<style>
			.hero {
				min-height: 100vh;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: flex-start;
				text-align: center;
				padding: 75px 1.5rem 3rem;
				gap: 0.25rem;
				max-width: 960px;
				margin: 0 auto;
			}
			.logo {
				width: min(960px, 90vw);
				height: auto;
				margin-bottom: 2rem;
				border-radius: 0;
			}
			.hero h1 {
				font-size: clamp(1.75rem, 5vw, 2.75rem);
				font-weight: 700;
				color: rgb(var(--black));
				margin: 0 0 0.5rem;
				letter-spacing: -0.01em;
			}
			.status {
				font-size: clamp(1.05rem, 2.4vw, 1.25rem);
				color: var(--accent);
				font-weight: 700;
				margin: 0 0 1.5rem;
				letter-spacing: 0.02em;
			}
			.mission {
				font-size: clamp(0.95rem, 2vw, 1.0625rem);
				color: rgb(var(--gray));
				line-height: 1.6;
				max-width: 32rem;
				margin: 0;
			}
		</style>
	</body>
</html>
